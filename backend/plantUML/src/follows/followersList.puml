@startuml followersList
!include ../../theme/theme-dark-seq.puml

title followers list flow
actor User
participant Resolver
participant FollowsService as F
database DB

User -> Resolver: followers()
Resolver -> F: getFollowers() : Follow[]

F -> DB: followRepo.find()
DB --> F: follow rows + follower relations

Resolver -> Resolver: map rows => follower users
F --> Resolver: rows
Resolver --> User: data.followers
@enduml
