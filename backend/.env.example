# Backend runtime environment (local development)
#
# Markings:
#   REQUIRED — must be set before the app will start
#   (default: X) — optional, falls back to X if unset

# App
NODE_ENV=development
# REQUIRED (in non-test environments)
PORT=3000

# ── Auth ──────────────────────────────────────────────
# REQUIRED: Generate a long random string for real usage.
JWT_SECRET=replace-with-a-long-random-secret
# (default: 15m)
JWT_EXPIRES_IN=15m
# (default: 8)
AUTH_MIN_PASSWORD_LENGTH=8

# ── Database (PostgreSQL) ─────────────────────────────
# REQUIRED (in non-test environments, must be non-empty)
DB_PASSWORD=replace-with-your-postgres-password
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_NAME=nest_graphql

# TypeORM schema sync
# Defaults to true in development, false elsewhere.
# Set explicitly to override — only safe with local databases.
DB_SYNCHRONIZE=true

# ── CORS ──────────────────────────────────────────────
# Comma-separated. Malformed URLs are skipped with a warning.
CORS_ORIGINS=http://localhost:19006,http://localhost:8081,http://localhost:3000

# ── GraphQL ───────────────────────────────────────────
# (default: 8)
GRAPHQL_MAX_DEPTH=8

# ── Rate Limiting ─────────────────────────────────────
# ttl is in milliseconds
RATE_LIMIT_TTL=60000
RATE_LIMIT_LIMIT=120

# ── App URLs ──────────────────────────────────────────
# (default: http://localhost:3000) Must be a valid http(s) URL.
APP_BASE_URL=http://localhost:3000

# ── Email Verification ────────────────────────────────
# For local testing with MailHog:
#   SMTP_HOST=localhost
#   SMTP_PORT=1025
#   SMTP_SECURE=false
#   EMAIL_FROM=mailhog@local.dev
SMTP_HOST=
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
# (default: no-reply@local.dev) Must be a valid email format.
EMAIL_FROM=no-reply@local.dev

# Verification token lifetime in seconds
# Use 86400 (24h) normally; set to 10 temporarily for local expiry testing.
EMAIL_VERIFICATION_TOKEN_TTL_SECONDS=86400

# Verification resend throttling
EMAIL_VERIFICATION_RESEND_COOLDOWN_MS=5000
EMAIL_VERIFICATION_RESEND_MAX_PER_HOUR=5
